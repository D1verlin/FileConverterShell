{
  "presets": {

    "vid-mp4-hq": {
      "category": "video",
      "label": "MP4 — High Quality (H.264)",
      "ext": "mp4",
      "args": ["-c:v", "h264_nvenc", "-rc", "vbr", "-cq", "18", "-preset", "p6", "-c:a", "aac", "-b:a", "192k", "-movflags", "+faststart"]
    },
    "vid-mp4-web": {
      "category": "video",
      "label": "MP4 — Web Optimized (H.264)",
      "ext": "mp4",
      "args": ["-c:v", "h264_nvenc", "-rc", "vbr", "-cq", "23", "-preset", "p4", "-c:a", "aac", "-b:a", "128k", "-movflags", "+faststart"]
    },
    "vid-mp4-small": {
      "category": "video",
      "label": "MP4 — Compressed (H.264)",
      "ext": "mp4",
      "args": ["-c:v", "h264_nvenc", "-rc", "vbr", "-cq", "28", "-preset", "p2", "-c:a", "aac", "-b:a", "96k", "-movflags", "+faststart"]
    },
    "vid-mp4-265": {
      "category": "video",
      "label": "MP4 — HEVC (H.265, GPU Accelerated)",
      "ext": "mp4",
      "args": ["-c:v", "hevc_nvenc", "-rc", "vbr", "-cq", "24", "-preset", "p4", "-c:a", "aac", "-b:a", "128k", "-tag:v", "hvc1"]
    },
    "vid-mp4-av1": {
      "category": "video",
      "label": "MP4 — AV1 (Next-Gen, GPU/CPU)",
      "ext": "mp4",
      "args": ["-c:v", "av1_nvenc", "-rc", "vbr", "-cq", "28", "-preset", "p4", "-c:a", "libopus", "-b:a", "128k"]
    },
    "vid-mp4-cpu": {
      "category": "video",
      "label": "MP4 — H.264 (CPU Only)",
      "ext": "mp4",
      "args": ["-c:v", "libx264", "-crf", "20", "-preset", "medium", "-c:a", "aac", "-b:a", "128k", "-movflags", "+faststart"]
    },
    "vid-webm": {
      "category": "video",
      "label": "WebM — VP9",
      "ext": "webm",
      "args": ["-c:v", "libvpx-vp9", "-crf", "30", "-b:v", "0", "-c:a", "libopus", "-b:a", "128k"]
    },
    "vid-webm-av1": {
      "category": "video",
      "label": "WebM — AV1 (libsvtav1)",
      "ext": "webm",
      "args": ["-c:v", "libsvtav1", "-crf", "30", "-preset", "6", "-c:a", "libopus", "-b:a", "128k"]
    },
    "vid-avi": {
      "category": "video",
      "label": "AVI — Windows Compatible",
      "ext": "avi",
      "args": ["-c:v", "mpeg4", "-q:v", "6", "-c:a", "mp3", "-b:a", "128k"]
    },
    "vid-mkv": {
      "category": "video",
      "label": "MKV — Lossless Copy",
      "ext": "mkv",
      "args": ["-c", "copy"]
    },
    "vid-mov": {
      "category": "video",
      "label": "MOV — QuickTime",
      "ext": "mov",
      "args": ["-c:v", "h264_nvenc", "-rc", "vbr", "-cq", "20", "-preset", "p4", "-c:a", "aac", "-b:a", "192k"]
    },
    "vid-gif": {
      "category": "video",
      "label": "Animated GIF",
      "ext": "gif",
      "args": ["-vf", "fps=15,scale=480:-1:flags=lanczos,split[s0][s1];[s0]palettegen[p];[s1][p]paletteuse", "-loop", "0"]
    },
    "vid-compress-discord-8mb": {
      "category": "video",
      "label": "Compress for Discord (under 8MB)",
      "ext": "mp4",
      "args": ["-c:v", "h264_nvenc", "-rc", "vbr", "-cq", "30", "-preset", "p4", "-maxrate", "800k", "-bufsize", "1600k", "-c:a", "aac", "-b:a", "64k", "-fs", "8M"]
    },
    "vid-compress-discord-25mb": {
      "category": "video",
      "label": "Compress for Discord (under 25MB)",
      "ext": "mp4",
      "args": ["-c:v", "h264_nvenc", "-rc", "vbr", "-cq", "26", "-preset", "p4", "-maxrate", "2500k", "-bufsize", "5000k", "-c:a", "aac", "-b:a", "96k", "-fs", "25M"]
    },
    "vid-resize-1080p": {
      "category": "video",
      "label": "Resize to 1080p (Full HD)",
      "ext": "mp4",
      "args": ["-c:v", "h264_nvenc", "-rc", "vbr", "-cq", "20", "-preset", "p4", "-vf", "scale=-2:1080:flags=lanczos", "-c:a", "aac", "-b:a", "128k"]
    },
    "vid-resize-720p": {
      "category": "video",
      "label": "Resize to 720p (HD)",
      "ext": "mp4",
      "args": ["-c:v", "h264_nvenc", "-rc", "vbr", "-cq", "22", "-preset", "p4", "-vf", "scale=-2:720:flags=lanczos", "-c:a", "aac", "-b:a", "128k"]
    },
    "vid-resize-480p": {
      "category": "video",
      "label": "Resize to 480p (SD)",
      "ext": "mp4",
      "args": ["-c:v", "h264_nvenc", "-rc", "vbr", "-cq", "24", "-preset", "p4", "-vf", "scale=-2:480:flags=lanczos", "-c:a", "aac", "-b:a", "96k"]
    },
    "vid-rotate-90-cw": {
      "category": "video",
      "label": "Rotate 90° Clockwise",
      "ext": "mp4",
      "args": ["-c:v", "h264_nvenc", "-rc", "vbr", "-cq", "20", "-preset", "p4", "-vf", "transpose=1", "-c:a", "copy"]
    },
    "vid-rotate-90-ccw": {
      "category": "video",
      "label": "Rotate 90° Counter-Clockwise",
      "ext": "mp4",
      "args": ["-c:v", "h264_nvenc", "-rc", "vbr", "-cq", "20", "-preset", "p4", "-vf", "transpose=2", "-c:a", "copy"]
    },
    "vid-rotate-180": {
      "category": "video",
      "label": "Rotate 180°",
      "ext": "mp4",
      "args": ["-c:v", "h264_nvenc", "-rc", "vbr", "-cq", "20", "-preset", "p4", "-vf", "transpose=2,transpose=2", "-c:a", "copy"]
    },
    "vid-flip-h": {
      "category": "video",
      "label": "Flip Horizontally",
      "ext": "mp4",
      "args": ["-c:v", "h264_nvenc", "-rc", "vbr", "-cq", "20", "-preset", "p4", "-vf", "hflip", "-c:a", "copy"]
    },
    "vid-flip-v": {
      "category": "video",
      "label": "Flip Vertically",
      "ext": "mp4",
      "args": ["-c:v", "h264_nvenc", "-rc", "vbr", "-cq", "20", "-preset", "p4", "-vf", "vflip", "-c:a", "copy"]
    },
    "vid-speed-2x": {
      "category": "video",
      "label": "Speed Up 2x",
      "ext": "mp4",
      "args": ["-c:v", "h264_nvenc", "-rc", "vbr", "-cq", "20", "-preset", "p4", "-vf", "setpts=0.5*PTS", "-filter:a", "atempo=2.0"]
    },
    "vid-speed-05x": {
      "category": "video",
      "label": "Slow Down 0.5x",
      "ext": "mp4",
      "args": ["-c:v", "h264_nvenc", "-rc", "vbr", "-cq", "20", "-preset", "p4", "-vf", "setpts=2.0*PTS", "-filter:a", "atempo=0.5"]
    },
    "vid-mute": {
      "category": "video",
      "label": "Mute Video (Remove Audio)",
      "ext": "mp4",
      "args": ["-c:v", "copy", "-an"]
    },
    "vid-extract-audio": {
      "category": "video",
      "label": "Extract Audio → MP3",
      "ext": "mp3",
      "args": ["-vn", "-c:a", "libmp3lame", "-b:a", "320k"]
    },
    "vid-extract-wav": {
      "category": "video",
      "label": "Extract Audio → WAV",
      "ext": "wav",
      "args": ["-vn", "-c:a", "pcm_s16le"]
    },
    "vid-extract-flac": {
      "category": "video",
      "label": "Extract Audio → FLAC",
      "ext": "flac",
      "args": ["-vn", "-c:a", "flac"]
    },
    "vid-extract-m4a": {
      "category": "video",
      "label": "Extract Audio → AAC (M4A)",
      "ext": "m4a",
      "args": ["-vn", "-c:a", "aac", "-b:a", "256k"]
    },
    "vid-extract-opus": {
      "category": "video",
      "label": "Extract Audio → Opus",
      "ext": "opus",
      "args": ["-vn", "-c:a", "libopus", "-b:a", "128k"]
    },

    "aud-mp3-hq": {
      "category": "audio",
      "label": "MP3 — High Quality (320 kbps)",
      "ext": "mp3",
      "args": ["-c:a", "libmp3lame", "-b:a", "320k", "-q:a", "0"]
    },
    "aud-mp3-std": {
      "category": "audio",
      "label": "MP3 — Standard (192 kbps)",
      "ext": "mp3",
      "args": ["-c:a", "libmp3lame", "-b:a", "192k"]
    },
    "aud-mp3-small": {
      "category": "audio",
      "label": "MP3 — Compressed (128 kbps)",
      "ext": "mp3",
      "args": ["-c:a", "libmp3lame", "-b:a", "128k"]
    },
    "aud-aac": {
      "category": "audio",
      "label": "AAC — 256 kbps (Apple/mobile)",
      "ext": "m4a",
      "args": ["-c:a", "aac", "-b:a", "256k", "-vn"]
    },
    "aud-m4a-alac": {
      "category": "audio",
      "label": "M4A — ALAC (Apple Lossless)",
      "ext": "m4a",
      "args": ["-c:a", "alac", "-vn"]
    },
    "aud-flac": {
      "category": "audio",
      "label": "FLAC — Lossless",
      "ext": "flac",
      "args": ["-c:a", "flac", "-compression_level", "8", "-vn"]
    },
    "aud-wav": {
      "category": "audio",
      "label": "WAV — PCM 16-bit",
      "ext": "wav",
      "args": ["-c:a", "pcm_s16le", "-vn"]
    },
    "aud-wav-24bit": {
      "category": "audio",
      "label": "WAV — PCM 24-bit",
      "ext": "wav",
      "args": ["-c:a", "pcm_s24le", "-vn"]
    },
    "aud-ogg": {
      "category": "audio",
      "label": "OGG — Vorbis",
      "ext": "ogg",
      "args": ["-c:a", "libvorbis", "-q:a", "6", "-vn"]
    },
    "aud-opus": {
      "category": "audio",
      "label": "Opus — Streaming (128 kbps)",
      "ext": "opus",
      "args": ["-c:a", "libopus", "-b:a", "128k", "-vn"]
    },
    "aud-wma": {
      "category": "audio",
      "label": "WMA — Windows Media Audio",
      "ext": "wma",
      "args": ["-c:a", "wmav2", "-b:a", "192k", "-vn"]
    },
    "aud-amr": {
      "category": "audio",
      "label": "AMR — Voice Quality",
      "ext": "amr",
      "args": ["-c:a", "libopencore_amrnb", "-ar", "8000", "-ab", "12.2k", "-ac", "1", "-vn"]
    },
    "aud-vol-200": {
      "category": "audio",
      "label": "Volume Boost (200%)",
      "ext": "mp3",
      "args": ["-c:a", "libmp3lame", "-b:a", "192k", "-filter:a", "volume=2.0", "-vn"]
    },
    "aud-vol-50": {
      "category": "audio",
      "label": "Volume Reduce (50%)",
      "ext": "mp3",
      "args": ["-c:a", "libmp3lame", "-b:a", "192k", "-filter:a", "volume=0.5", "-vn"]
    },

    "img-jpg-hq": {
      "category": "image",
      "label": "JPEG — High Quality (95%)",
      "ext": "jpg",
      "args": ["-q:v", "2"]
    },
    "img-jpg-web": {
      "category": "image",
      "label": "JPEG — Web (80%)",
      "ext": "jpg",
      "args": ["-q:v", "5"]
    },
    "img-jpg-small": {
      "category": "image",
      "label": "JPEG — Small (60%)",
      "ext": "jpg",
      "args": ["-q:v", "10"]
    },
    "img-png": {
      "category": "image",
      "label": "PNG — Lossless",
      "ext": "png",
      "args": ["-compression_level", "9"]
    },
    "img-webp": {
      "category": "image",
      "label": "WebP — Lossy (quality 85)",
      "ext": "webp",
      "args": ["-quality", "85"]
    },
    "img-webp-lossless": {
      "category": "image",
      "label": "WebP — Lossless",
      "ext": "webp",
      "args": ["-lossless", "1"]
    },
    "img-avif": {
      "category": "image",
      "label": "AVIF — Modern (quality 60)",
      "ext": "avif",
      "args": ["-c:v", "libaom-av1", "-crf", "30", "-still-picture", "1"]
    },
    "img-bmp": {
      "category": "image",
      "label": "BMP — Bitmap",
      "ext": "bmp",
      "args": []
    },
    "img-tiff": {
      "category": "image",
      "label": "TIFF — Lossless",
      "ext": "tiff",
      "args": ["-compression_algo", "lzw"]
    },
    "img-ico": {
      "category": "image",
      "label": "ICO — Windows Icon (256x256)",
      "ext": "ico",
      "args": ["-vf", "scale=256:256:force_original_aspect_ratio=decrease"]
    },
    "img-resize-hd": {
      "category": "image",
      "label": "JPEG — Resize to HD (1920px max)",
      "ext": "jpg",
      "args": ["-vf", "scale=min(1920\\,iw):min(1080\\,ih):force_original_aspect_ratio=decrease", "-q:v", "3"]
    },
    "img-resize-4k": {
      "category": "image",
      "label": "JPEG — Resize to 4K (3840px max)",
      "ext": "jpg",
      "args": ["-vf", "scale=min(3840\\,iw):min(2160\\,ih):force_original_aspect_ratio=decrease", "-q:v", "2"]
    },
    "img-resize-thumb": {
      "category": "image",
      "label": "JPEG — Thumbnail (320x240)",
      "ext": "jpg",
      "args": ["-vf", "scale=320:240:force_original_aspect_ratio=decrease", "-q:v", "5"]
    },
    "img-resize-square": {
      "category": "image",
      "label": "JPEG — Square Crop (512x512)",
      "ext": "jpg",
      "args": ["-vf", "crop=min(iw\\,ih):min(iw\\,ih),scale=512:512", "-q:v", "3"]
    },
    "img-grayscale": {
      "category": "image",
      "label": "Convert to Grayscale",
      "ext": "jpg",
      "args": ["-vf", "format=gray", "-q:v", "2"]
    },
    "img-rotate-90-cw": {
      "category": "image",
      "label": "Rotate 90° Clockwise",
      "ext": "jpg",
      "args": ["-vf", "transpose=1", "-q:v", "2"]
    },
    "img-rotate-90-ccw": {
      "category": "image",
      "label": "Rotate 90° Counter-Clockwise",
      "ext": "jpg",
      "args": ["-vf", "transpose=2", "-q:v", "2"]
    },
    "img-rotate-180": {
      "category": "image",
      "label": "Rotate 180°",
      "ext": "jpg",
      "args": ["-vf", "transpose=2,transpose=2", "-q:v", "2"]
    },
    "img-flip-h": {
      "category": "image",
      "label": "Flip Horizontally",
      "ext": "jpg",
      "args": ["-vf", "hflip", "-q:v", "2"]
    },
    "img-flip-v": {
      "category": "image",
      "label": "Flip Vertically",
      "ext": "jpg",
      "args": ["-vf", "vflip", "-q:v", "2"]
    }

  }
}
